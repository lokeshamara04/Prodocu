    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.16.10",
    "@types/uuid": "^10.0.0",
    "adm-zip": "^0.5.16",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "docx": "^9.0.2",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "marked": "^14.1.2",
    "md-to-pdf": "^5.2.4",
    "multer": "^1.4.5-lts.1",
