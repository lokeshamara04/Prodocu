# ─── Required ────────────────────────────────────────────────────────────────

# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ─── Required for auth (generate with: openssl rand -base64 32) ──────────────
JWT_SECRET=change-to-a-random-secret-in-production

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (default, great for local dev):
DATABASE_URL=file:./dev.db
# PostgreSQL (production):  DATABASE_URL=postgresql://user:pass@host:5432/prodocu
# MySQL (production):        DATABASE_URL=mysql://user:pass@host:3306/prodocu

# ─── Optional ────────────────────────────────────────────────────────────────

# Frontend URL (for CORS). Defaults to http://localhost:3000
FRONTEND_URL=http://localhost:3000

# Server port. Defaults to 4000
PORT=4000

# OpenRouter model to use. Defaults to openai/gpt-4o
# See available models: https://openrouter.ai/models
# Examples: openai/gpt-4o, anthropic/claude-sonnet-4, google/gemini-2.0-flash
# OPENROUTER_MODEL=openai/gpt-4o

# AWS S3 bucket for zip uploads (required in production).
# Defaults to "prodocu-uploads" in the code, but set this explicitly in production.
S3_UPLOADS_BUCKET=prodocu-uploads

# AWS region (for S3). Defaults to us-east-1
# AWS_REGION=us-east-1

# GitHub personal access token (optional — increases API rate limits for tarball downloads)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Max uploaded zip file size in MB. Defaults to 50
# MAX_ZIP_SIZE_MB=50

# Node environment
# NODE_ENV=development
