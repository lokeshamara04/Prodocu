{
  "name": "prodocu",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "description": "AI-powered project documentation generator — monorepo",
  "workspaces": ["frontend", "backend"],
  "scripts": {
    "dev": "concurrently -n fe,be -c cyan,yellow \"npm run dev -w frontend\" \"npm run dev -w backend\"",
    "build": "npm run build -w backend && npm run build -w frontend",
    "start": "npm run start -w backend",
    "db:push": "npm run db:push -w backend",
    "db:studio": "npm run db:studio -w backend"
  },
  "devDependencies": {
    "@types/node": "^20.16.10",
    "concurrently": "^8.2.0"
  }
}